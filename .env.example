# ──────────────────────────────────────────────────────────────────────────────
# Entreprendre Ensemble pour Châteauneuf — Variables d'environnement
# Copier ce fichier en .env et renseigner les vraies valeurs
# ──────────────────────────────────────────────────────────────────────────────

# Mot de passe admin (hash bcrypt)
# Générer : php -r "echo password_hash('VotreMotDePasse', PASSWORD_DEFAULT);"
ADMIN_PASSWORD_HASH=

# Brevo (ex-Sendinblue) — API & SMTP
BREVO_API_KEY=
BREVO_LIST_ID=
BREVO_SMTP_USER=
BREVO_SMTP_PASS=
