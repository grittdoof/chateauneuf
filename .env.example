# ──────────────────────────────────────────────────────────────────────────────
# Entreprendre Ensemble pour Châteauneuf — Variables d'environnement
# Copier ce fichier en .env et renseigner les vraies valeurs
# Sur Vercel : Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# Mot de passe admin (hash bcrypt)
# Générer : node -e "const b=require('bcryptjs');console.log(b.hashSync('VotreMotDePasse',12))"
ADMIN_PASSWORD_HASH=

# SMTP (Brevo relay)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@ensemblepourchateauneuf.fr
SMTP_FROM_NAME=Entreprendre Ensemble pour Chateauneuf

# Email destinataire (notifications équipe, séparé par des virgules)
EMAIL_TO=

# Brevo API (optionnel — pour gestion contacts dans l'admin)
BREVO_API_KEY=
BREVO_LIST_ID=2
